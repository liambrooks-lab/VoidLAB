# --- VOIDLAB SYSTEM CONFIG ---
PORT=5000
NODE_ENV=development

# --- FRONTEND CONFIG ---
# The URL where your frontend will run
NEXT_PUBLIC_API_URL=http://localhost:5000

# --- DATABASE (Supabase/PostgreSQL) ---
# You will get these once we set up the database
DATABASE_URL="postgresql://postgres:password@localhost:5432/voidlab"
DIRECT_URL="postgresql://postgres:password@localhost:5432/voidlab"

# --- COMPILER API ---
# Judge0 CE is used for public cloud execution
JUDGE0_API_URL=https://ce.judge0.com

# --- AUTHENTICATION ---
# Secret key for signing login tokens
JWT_SECRET=your_super_secret_voidlab_key_123
